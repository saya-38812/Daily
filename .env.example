# Claude APIキー（https://console.anthropic.com で取得）
ANTHROPIC_API_KEY=your_api_key_here

# 振り返りログが入っているスプレッドシートのID
# URLの https://docs.google.com/spreadsheets/d/【ここ】/edit の部分
SPREADSHEET_ID=your_spreadsheet_id_here

# データが入っているシート名（デフォルト: シート1）
SHEET_NAME=振り返りログ

# Google Docsのレポートを保存するフォルダID（省略可）
# URLの https://drive.google.com/drive/folders/【ここ】 の部分
DOCS_FOLDER_ID=your_folder_id_here

# 対象のカレンダーID（省略するとメインカレンダーを使用）
# Googleカレンダーの設定 > カレンダーの統合 で確認できる
CALENDAR_ID=primary

# コーチングサマリーを書き込むシート名（デフォルト: コーチングサマリー）
SUMMARY_SHEET_NAME=コーチングサマリー

# Gmail からメールを取得する日数（デフォルト: 3日）
GMAIL_FETCH_DAYS=3

# コーチングレポートの送信先メールアドレス（省略するとログインアカウント自身に送る）
REPORT_EMAIL_TO=your_email@gmail.com

